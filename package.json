{
  "name": "reino-dos-expoentes-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:web": "npm run dev -w @reino/web",
    "dev:mobile": "npm run start -w @reino/mobile",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^24.10.3",
    "typescript": "^5.9.3",
    "vitest": "^3.1.1"
  }
}
